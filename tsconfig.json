{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "@stanok/core": ["./packages/core/index.ts"],
      "@stanok/core/*": ["./packages/core/lib/*"],
      "@stanok/plugin-jira": ["./packages/plugin-jira/index.ts"],
      "@stanok/plugin-bitbucket": ["./packages/plugin-bitbucket/index.ts"],
      "@stanok/plugin-ide": ["./packages/plugin-ide/index.ts"],
      "@stanok/plugin-claude": ["./packages/plugin-claude/index.ts"],
      "@stanok/plugin-agent-cli": ["./packages/plugin-agent-cli/index.ts"],
      "@stanok/plugin-portless": ["./packages/plugin-portless/index.ts"]
    }
  }
}
