{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "private": true,
  "name": "stanok",
  "title": "Stanok",
  "description": "Manage parallel worktree-based development environments",
  "icon": "extension-icon.png",
  "author": "viktor",
  "license": "MIT",
  "commands": [
    {
      "name": "start",
      "title": "Start Worktree",
      "subtitle": "Stanok",
      "description": "Start or reopen a worktree for a task",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@stanok/core": "workspace:*",
    "@raycast/api": "^1.83.0",
    "@raycast/utils": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "lint": "ray lint"
  }
}
